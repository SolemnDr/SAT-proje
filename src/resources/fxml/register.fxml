<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="560" prefWidth="360" spacing="0" styleClass="root-pane" stylesheets="@/style/dark.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="gui.RegisterController">

    <VBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 24 0;">
        <Label styleClass="logo-title" text="GameStore" />
        <Label styleClass="logo-sub" text="Yeni Hesap Oluştur" />
    </VBox>

    <VBox spacing="14" style="-fx-padding: 0 36 0 36;">

        <VBox spacing="5">
            <Label styleClass="field-label" text="KULLANICI ADI" />
            <TextField fx:id="usernameField" promptText="Kullanıcı adınızı giriniz" styleClass="field-input" />
        </VBox>

        <VBox spacing="5">
            <Label styleClass="field-label" text="E-POSTA" />
            <TextField fx:id="emailField" promptText="e-posta adresinizi giriniz" styleClass="field-input" />
        </VBox>

        <VBox spacing="5">
            <Label styleClass="field-label" text="ŞİFRE" />
            <PasswordField fx:id="passwordField" promptText="Şifrenizi giriniz" styleClass="field-input" />
        </VBox>

        <VBox spacing="5">
            <Label styleClass="field-label" text="HESAP TÜRÜ" />
            <ComboBox fx:id="roleComboBox" maxWidth="Infinity" styleClass="field-input" />
        </VBox>

        <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true" />

        <Button maxWidth="Infinity" onAction="#handleRegister" styleClass="btn-primary" text="Kayıt Ol" />

        <Label alignment="CENTER" maxWidth="Infinity" styleClass="divider-label" text="Zaten hesabın var mı?" />

        <Button maxWidth="Infinity" onAction="#handleLogin" styleClass="btn-secondary" text="Giriş Yap" />

    </VBox>
</VBox>
